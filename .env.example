DB_USER_NM = postgres
DB_USER_PW = postgres
DB_HOST = 0.0.0.0
DB_PORT = 5432
DB_NAME = greekdb


SECRET_KEY = EXXAMPLE0123

# Frontend base URL used to build password-reset links
FRONTEND_URL=https://greekgeek.app

# Transactional email via ZeptoMail HTTP API (port 443 — SMTP ports are blocked on the
# DigitalOcean droplet). ZEPTOMAIL_TOKEN is the ZeptoMail Mail Agent "Send Mail" token.
ZEPTOMAIL_TOKEN=
DEFAULT_FROM_EMAIL=no-reply@greekgeek.app
# Optional override (defaults to the .com region):
# ZEPTOMAIL_API_URL=https://api.zeptomail.com/v1.1/email

# Stripe Billing
# Prefer a restricted key (`rk_...`) with only the permissions this backend needs.
STRIPE_PUBLISHABLE_KEY=
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Price ID for the $149.99/year organization subscription.
STRIPE_ORG_PRICE_ID=
# Optional overrides for Stripe Checkout redirects.
STRIPE_BILLING_SUCCESS_URL="https://greekgeek.app/success/?stripe_checkout=success&session_id={CHECKOUT_SESSION_ID}"
STRIPE_BILLING_CANCEL_URL="https://greekgeek.app/"

# Temporary prod/sandbox testing shortcut. Keep false except during manual checkout testing.
FAST_TEST_REGISTRATION_ENABLED=false
